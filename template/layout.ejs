<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= frontmatter.title %> ‹ Tota Scriptura</title>
  
</head>
<body>
  <header>
    <a href="/">Tota Scriptura</a>
  </header>
  <main>
    <article>
      <h1><%= frontmatter.title %><% if (frontmatter.featured) { %> <span class="featured-badge">&starf;</span><% } %></h1>
      
			<%- content %>
    </article>

    <% if (subcategories.length > 0) { %>
    <section>
      <h2>Subcategories</h2>
      <ul>
        <% subcategories.forEach(function(sub) { %>
        <li><a href="<%= sub.url %>"><%= sub.title %></a></li>
        <% }); %>
      </ul>
    </section>
    <% } %>

    <% if (pages.length > 0) { %>
    <section>
      <h2>Pages in this category</h2>
      <ul>
        <% pages.forEach(function(page) { %>
        <li><a href="<%= page.url %>"><%= page.title %></a></li>
        <% }); %>
      </ul>
    </section>
    <% } %>

    <% if (categories.length > 0) { %>
    <p>Categories: <% categories.forEach(function(cat, i) { %><a href="<%= cat.url %>"><%= cat.title %></a><%= i < categories.length - 1 ? ', ' : '' %><% }); %></p>
    <% } %>

    <% if (asideOf) { %>
    <p>Aside of <a href="<%= asideOf.url %>"><%= asideOf.title %></a></p>
    <% } %>

    <% if (asides.length > 0) { %>
    <section>
      <h2>Asides</h2>
      <ul>
        <% asides.forEach(function(aside) { %>
        <li><a href="<%= aside.url %>"><%= aside.title %></a></li>
        <% }); %>
      </ul>
    </section>
    <% } %>
  </main>
  
  <nav>
    <menu>
      <li><a href="/about">About this project</a></li>
      <li><a href="/index/alphabetical">Alphabetical index</a></li>
      <li><a href="/index/categorical">Categorical index</a></li>
      <li><a href="/index/featured">Featured topics</a></li>
    </menu>
  </nav>
	
	<footer>
		<p>Copyright &copy; 2009–<%= Temporal.Now.plainDateISO().year % 100 %></p>
		
		<menu>
			<li>About</li>
			<li>Colophon</li>
		</menu>
	</footer>
  
</body>
</html>